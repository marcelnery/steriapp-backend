{
  "version": 2,

  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    }
  ],

  "routes": [

    {
      "src": "/banners/(.*)",
      "dest": "/src/public/banners/$1"
    },

    {
      "src": "/reset-password.html",
      "dest": "/src/public/reset-password.html"
    },

    {
      "src": "/(.*)",
      "dest": "src/server.js"
    }

  ]
}

